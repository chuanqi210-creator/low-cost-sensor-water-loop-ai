      "timestamp_fields": [
        "event_time_min",
        "matched_lab_sample_time_min"
      ],
      "primary_key": [
        "campaign_id",
        "batch_id",
        "bed_id",
        "event_time_min"
      ]
    },
    "fast_proxy_event_log": {
      "description": "基质冲击快代理事件与现场标签，用于 precision/recall、提前量和误触发成本校准。",
