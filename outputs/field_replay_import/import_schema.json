      "timestamp_fields": [
        "timestamp_min"
      ],
      "primary_key": [
        "batch_id",
        "timestamp_min"
      ]
    },
    "offline_lab_results": {
      "description": "离线标签与结果返回时间，用于计算检测 turnaround 和快代理标签。",
