      "timestamp_fields": [
        "sample_time_min",
        "result_time_min"
      ],
      "primary_key": [
        "batch_id",
        "sample_time_min",
        "analyte"
      ]
    },
    "campaign_operation_log": {
      "description": "控制动作命令、执行和生效时间，用于计算执行器/预处理延迟。",
      "required_fields": [
        "campaign_id",
        "batch_id",
        "action_id",
        "command_time_min",
        "effect_time_min",
        "start_min",
        "end_min",
        "release_policy"
      ],
      "optional_fields": [
        "recycle_ratio",
        "tank_storage_margin",
        "actuator_latency_p90",
        "pump_valve_result",
        "hold_time_min",
        "regeneration_event",
        "bed_id",
        "pressure_headloss_review_required"
